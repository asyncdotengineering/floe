{
  "name": "floe-workspace",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "test:live": "pnpm --filter @floe/example-support-bot test:live",
    "check:types": "pnpm -r exec tsc --noEmit",
    "dev:example": "pnpm --filter @floe/example-support-bot dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
