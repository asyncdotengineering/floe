{
  "name": "@floe/server-bootstrap",
  "version": "0.1.0",
  "description": "Node HTTP bootstrap for Floe Assistants. One function, sane defaults, escape hatches for the openai-compat mux and async pre-listen lifecycle (mock-MCP servers etc).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "README.md"],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@floe/adapter-web": "workspace:*",
    "@floe/runtime": "workspace:*"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
