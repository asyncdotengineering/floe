{
  "name": "@floe/adapter-slack",
  "version": "0.1.0",
  "description": "Slack channel adapter for Floe Assistants. Verifies signed requests, routes Events API webhooks (DMs + @mentions) into Floe conversations, posts replies via the Slack Web API.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "README.md"],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@floe/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
