# Provider API key (pick one matching FLOE_MODEL)
OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

FLOE_MODEL=openai/gpt-4.1-mini

# Mock service ports
CEDAR_MOCK_FHIR_PORT=4201
CEDAR_MOCK_RX_PORT=4202
CEDAR_MOCK_BILLING_PORT=4203

# Server port
PORT=3130

# Twilio (only required to wire the PSTN path)
TWILIO_VOICE_WEBHOOK_URL=
