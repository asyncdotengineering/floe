# Provider API key (pick one matching FLOE_MODEL)
OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

FLOE_MODEL=openai/gpt-4.1-mini

# Mock service ports
KW_MOCK_NOTION_PORT=4301
KW_MOCK_LINEAR_PORT=4302
KW_MOCK_CALENDAR_PORT=4303
KW_MOCK_EMAIL_PORT=4304

# Server port
PORT=3140

# Slack — only needed for the Slack DM channel (optional)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# Owner identity — used as the memory key + the "me@…" address the
# bot recognizes when scanning your inbox/calendar.
OWNER_EMAIL=me@acme.example
OWNER_USER_ID=u_me
