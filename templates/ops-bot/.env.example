# ────────────────────────────────────────────────────────────────
# Required to run: provider API key (LLM)
# ────────────────────────────────────────────────────────────────
# Pick ONE based on the FLOE_MODEL value below.
OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

# ────────────────────────────────────────────────────────────────
# Model selection (any provider Pi supports)
# ────────────────────────────────────────────────────────────────
FLOE_MODEL=openai/gpt-4.1-mini

# ────────────────────────────────────────────────────────────────
# Slack — only required if you wire the Slack adapter in server.ts.
# Without these, the web channel still works on `/agents/web/<sessionId>`.
# ────────────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# ────────────────────────────────────────────────────────────────
# Mock-service ports (defaults are usually fine)
# ────────────────────────────────────────────────────────────────
OPS_MOCK_OKTA_PORT=4001
OPS_MOCK_NOTION_PORT=4002
OPS_MOCK_LINEAR_PORT=4003

# ────────────────────────────────────────────────────────────────
# Server port
# ────────────────────────────────────────────────────────────────
PORT=3110
