# Provider API key (pick one matching FLOE_MODEL)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Higher tier than the other templates — comms drafting + strategic
# briefings are higher-stakes than support replies. Default to a
# stronger model for production.
FLOE_MODEL=openai/gpt-4.1-mini

# Mock service ports
COS_MOCK_NOTION_PORT=4401
COS_MOCK_LINEAR_PORT=4402
COS_MOCK_CALENDAR_PORT=4403
COS_MOCK_EMAIL_PORT=4404
COS_MOCK_COMMITMENTS_PORT=4405
# Background-job runner MCP port (from @floe/jobs)
COS_JOBS_PORT=4406

# Server port
PORT=3150

# Slack — optional, for DM-based "quick brief me" use
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# Leader identity — this template works for ONE person. Everything is
# keyed to this user; memory accumulates indefinitely.
LEADER_NAME=Carol Marsh
LEADER_EMAIL=carol@acme.example
LEADER_USER_ID=u_carol
