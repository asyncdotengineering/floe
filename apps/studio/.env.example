# The Floe agent URL — point this at any running template:
#   templates/ops-bot:           http://localhost:3110
#   templates/hearth-bot:        http://localhost:3120
#   templates/cedar-health:      http://localhost:3130
#   templates/knowledge-worker:  http://localhost:3140
#   templates/chief-of-staff:    http://localhost:3150
#
# Studio talks to the agent's openai-compat endpoint
# (`<FLOE_AGENT_URL>/v1/chat/completions`). The template MUST run
# with `openaiCompat: true` in runServer() — every shipped template does.
FLOE_AGENT_URL=http://localhost:3110

# Optional — label shown in the UI header. Cosmetic only; doesn't
# change routing.
VITE_AGENT_NAME="Floe Agent"
